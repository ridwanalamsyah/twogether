# Optional: HTTP endpoint that accepts the sync queue payloads.
# When unset, all data stays local and the queue keeps "pending" items.
# Expected request body:
#   { table: string, recordId: string, op: "upsert" | "delete", payload: object }
NEXT_PUBLIC_SYNC_URL=

# Optional: Supabase credentials if you wire Supabase client in later.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
